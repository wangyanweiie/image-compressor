[Unit]
Description=Image Compressor Flask Application
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/path/to/image-compressor
Environment="PATH=/path/to/venv/bin"
ExecStart=/path/to/venv/bin/gunicorn --workers 3 --bind unix:image-compressor.sock -m 007 app:app
Restart=always

[Install]
WantedBy=multi-user.target
